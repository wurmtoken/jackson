---
const nav = [
  ['Home','/'],['Services','/services/'],['Process','/our-striping-process/'],['ADA Guide','/ada-compliance-guide/'],['Service Areas','/ridgeland/'],['Contact','/contact/']
];
---
<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="Jackson Lot Striping home">
      <span class="brand-mark">JL</span>
      <span>Jackson<br /><strong>Lot Striping</strong></span>
    </a>
    <a class="header-phone" href="tel:+16013654753">CALL NOW</a>
  </div>
  <div class="nav-bar">
    <div class="container nav-wrap">
      <nav aria-label="Main navigation"><ul>{nav.map(([label,href]) => <li><a href={href}>{label}</a></li>)}</ul></nav>
    </div>
  </div>
</header>
