---
import BaseLayout from '../layouts/BaseLayout.astro';
const site = 'https://jacksonlotstriping.com';

export function getStaticPaths() {
  const pageData = {
    'our-striping-process': {title:'Our Striping Process | Jackson Lot Striping',description:'Step-by-step parking lot striping process for Jackson MS properties, including walkthroughs, measurements, chalk layout, prep, paint, curing, ADA checks, and final inspection.',eyebrow:'Process',h1:'Our Striping Process',lead:'A clean striping job starts before paint hits the pavement. The lot has to be measured, traffic has to be considered, and the surface needs to be ready for paint to bond in Mississippi heat and humidity.',type:'process'},
    'how-mississippi-weather-affects-parking-lot-striping': {title:'How Mississippi Weather Affects Parking Lot Striping',description:'How Mississippi heat, humidity, rain, UV fading, and traffic wear affect parking lot striping schedules and repaint timing.',eyebrow:'Mississippi Weather',h1:'How Mississippi Weather Affects Parking Lot Striping',lead:'In Mississippi, parking lot markings often fade faster because of heat, humidity, heavy rain, UV exposure, and constant traffic at entrances, fire lanes, and loading zones.',type:'weather'},
    'thermoplastic-vs-standard-traffic-paint': {title:'Thermoplastic vs Standard Traffic Paint | Jackson Lot Striping',description:'Compare thermoplastic and standard traffic paint for Jackson MS loading zones, warehouse traffic, retail lots, and Mississippi climate conditions.',eyebrow:'Materials',h1:'Thermoplastic vs Standard Traffic Paint',lead:'Standard traffic paint and thermoplastic both have a place. The right material depends on traffic load, budget, pavement condition, expected lifespan, and how quickly the lot needs to reopen.',type:'thermo'},
    'ada-compliance-guide': {title:'ADA Compliance Guide | Jackson Lot Striping',description:'Guide to ADA parking lot markings, handicap spacing, access aisles, signage, fire lane visibility, common violations, and repaint schedules.',eyebrow:'ADA Guide',h1:'ADA Compliance Guide for Parking Lot Markings',lead:'Accessible parking is more than a blue symbol. Stall spacing, access aisles, signs, routes to the entrance, and visibility all affect how usable the space is.',type:'ada'},
    'parking-lot-layout-planning': {title:'Parking Lot Layout Planning | Jackson Lot Striping',description:'Parking lot layout planning for Jackson MS properties, including traffic flow, pedestrian safety, parking efficiency, loading zones, arrows, apartments, and retail layouts.',eyebrow:'Layout Planning',h1:'Parking Lot Layout Planning',lead:'Good layout work makes a property easier to use. The goal is clear traffic flow, safer pedestrian routes, usable stalls, and fewer conflicts between customers, tenants, and delivery drivers.',type:'layout'},
    ridgeland: {title:'Parking Lot Striping in Ridgeland MS | Jackson Lot Striping',description:'Ridgeland parking lot striping for retail centers, office parks, medical plazas, apartments, and high-traffic commercial properties.',eyebrow:'Service Area',h1:'Parking Lot Striping in Ridgeland, MS',lead:'Ridgeland properties often include retail centers, office parks, medical plazas, apartments, and restaurants where steady customer traffic wears entrances and stop bars quickly.',type:'local',city:'Ridgeland',details:['Retail corridors need readable arrows, crosswalks, stop bars, and fire lanes because traffic turns over all day.','Medical and office properties need ADA stalls, access aisles, and pedestrian routes that are visible in bright sun and wet weather.','Apartment properties usually need phased striping so tenants are not blocked from buildings or garages.']},
    madison: {title:'Parking Lot Striping in Madison MS | Jackson Lot Striping',description:'Madison parking lot striping for schools, churches, offices, retail centers, restaurants, and apartment communities.',eyebrow:'Service Area',h1:'Parking Lot Striping in Madison, MS',lead:'Madison lots often include schools, churches, offices, restaurants, neighborhood retail, and residential communities where scheduling matters as much as paint quality.',type:'local',city:'Madison',details:['School and church lots often need crosswalks, arrows, drop-off areas, and work windows around services, events, and pickup times.','Restaurant and retail pads may need early morning or overnight striping to avoid customer disruption.','Heat and UV exposure can fade open parking lots faster than shaded or lower-traffic properties.']},
    pearl: {title:'Parking Lot Striping in Pearl MS | Jackson Lot Striping',description:'Pearl parking lot striping for shopping centers, hotels, warehouses, restaurants, apartments, and commercial properties near busy corridors.',eyebrow:'Service Area',h1:'Parking Lot Striping in Pearl, MS',lead:'Pearl commercial lots often handle shopping center traffic, hotel parking, warehouse access, restaurants, and steady traffic near busy corridors.',type:'local',city:'Pearl',details:['Shopping centers need clear traffic flow, fire lanes, stop bars, and pedestrian crossings because vehicles turn over all day.','Warehouse and service areas may need loading-zone layouts that separate trucks, employees, and customers.','Rain and humidity can shift scheduling, especially when a lot needs to reopen quickly for retail or hotel traffic.']},
    brandon: {title:'Parking Lot Striping in Brandon MS | Jackson Lot Striping',description:'Brandon parking lot striping for retail, schools, churches, apartments, medical offices, restaurants, and commercial lots.',eyebrow:'Service Area',h1:'Parking Lot Striping in Brandon, MS',lead:'Brandon projects often involve retail centers, schools, churches, apartments, restaurants, and medical offices where clear markings help visitors move through the property without confusion.',type:'local',city:'Brandon',details:['School, church, and medical properties benefit from visible crosswalks, arrows, ADA spaces, and no-parking zones.','Apartment lots require tenant coordination and phased closures so residents have access during repainting.','Entrance lanes and stop bars can fade sooner because turning tires and heat concentrate wear in those areas.']},
    clinton: {title:'Parking Lot Striping in Clinton MS | Jackson Lot Striping',description:'Clinton parking lot striping for schools, churches, retail centers, apartments, offices, and commercial properties.',eyebrow:'Service Area',h1:'Parking Lot Striping in Clinton, MS',lead:'Clinton lots often include schools, churches, retail pads, apartments, and offices where work needs to be scheduled around events, class traffic, and tenant access.',type:'local',city:'Clinton',details:['Church and school lots often need weekend, break-period, or off-hour scheduling so striping does not interfere with peak traffic.','Small commercial lots may need careful layout planning to preserve parking count without creating tight turns.','Fire lanes and ADA markings should be inspected regularly because they can fade faster in open sun and heavy rain.']},
    flowood: {title:'Parking Lot Striping in Flowood MS | Jackson Lot Striping',description:'Flowood parking lot striping for medical plazas, retail centers, restaurants, offices, warehouses, and apartment communities.',eyebrow:'Service Area',h1:'Parking Lot Striping in Flowood, MS',lead:'Flowood has medical plazas, retail centers, restaurants, offices, apartments, and warehouse/service properties where traffic flow and ADA visibility matter every day.',type:'local',city:'Flowood',details:['Medical and office lots need clear accessible stalls, access aisles, pedestrian crossings, and directional markings.','Retail and restaurant lots often need phased or overnight scheduling to keep customer access open.','Loading zones and rear service drives wear faster when delivery traffic turns in the same spots every day.']},
    byram: {title:'Parking Lot Striping in Byram MS | Jackson Lot Striping',description:'Byram parking lot striping for neighborhood retail, apartments, churches, schools, restaurants, warehouses, and commercial lots.',eyebrow:'Service Area',h1:'Parking Lot Striping in Byram, MS',lead:'Byram lots often include neighborhood retail, apartments, churches, restaurants, schools, and service businesses where faded markings can make tight lots harder to use.',type:'local',city:'Byram',details:['Smaller retail lots need clear stall lines, arrows, and no-parking markings so customers do not block entrances or drive aisles.','Apartments and churches often need phased or weekend scheduling depending on tenant and event traffic.','Rain, humidity, and asphalt texture affect how quickly paint dries and how consistent the finished line looks.']}
  };
  return Object.entries(pageData).map(([slug, page]) => ({ params: { slug }, props: { slug, page } }));
}

const { slug, page } = Astro.props;
const breadcrumb = {'@context':'https://schema.org','@type':'BreadcrumbList','itemListElement':[{'@type':'ListItem','position':1,'name':'Home','item':site+'/'},{'@type':'ListItem','position':2,'name':page.h1,'item':`${site}/${slug}/`}]};
const service = {'@context':'https://schema.org','@type':'Service','name':page.h1,'provider':{'@type':'LocalBusiness','name':'Jackson Lot Striping'},'areaServed':page.city || 'Jackson MS','url':`${site}/${slug}/`};
---
<BaseLayout title={page.title} description={page.description} canonical={`${site}/${slug}/`} schemas={[breadcrumb, service]}>
  <section class="page-hero"><div class="container"><p class="breadcrumb"><a href="/">Home</a> / {page.h1}</p><p class="eyebrow">{page.eyebrow}</p><h1>{page.h1}</h1><p>{page.lead}</p><div class="cta-row"><a class="button" href="/contact/#quote-form">Request Site Visit</a><a class="btn secondary" href="/services/">View Services</a></div></div></section>
  {page.type === 'process' && <section class="section"><div class="container narrow-copy"><h2>How a Typical Job Moves</h2><ol class="process-list"><li><strong>Site walkthrough:</strong> We look at entrances, drive aisles, ADA spaces, fire lanes, loading zones, pedestrian paths, drainage, pavement texture, and active traffic.</li><li><strong>Measurements:</strong> Stall widths, aisle dimensions, access aisles, wheel stop spacing, crosswalks, and stencil locations are measured against the usable pavement.</li><li><strong>Layout planning:</strong> We confirm traffic direction, tenant access, closure sequence, and whether the lot should be striped in phases.</li><li><strong>Surface prep:</strong> Loose debris, moisture, and problem areas are addressed before painting.</li><li><strong>Chalk layout:</strong> Critical lines, stencils, and arrows are chalked so spacing problems are caught early.</li><li><strong>Striping application:</strong> Lines, arrows, ADA symbols, curbs, fire lanes, and stencils are applied with attention to paint thickness, overspray, and alignment.</li><li><strong>Drying and curing:</strong> Reopening depends on heat, humidity, shade, airflow, and paint type.</li><li><strong>ADA verification:</strong> Accessible stalls, access aisles, symbols, and routes are checked against the agreed layout.</li><li><strong>Final inspection:</strong> We walk the job, remove cones when safe, and note any areas that need touch-up.</li></ol></div></section>}
  {page.type === 'weather' && <section class="section"><div class="container split"><article><h2>Why Mississippi Lots Fade Quickly</h2><p>Heat, humidity, heavy rain, UV exposure, and constant tire traffic all shorten marking life. Entrances, fire lanes, stop bars, loading zones, and shopping center drive aisles usually fade before low-traffic parking rows.</p><p>Striping schedules also depend on pavement moisture. If rain moves in or humidity slows drying, it is better to adjust the schedule than paint over a surface that will not hold a clean line.</p></article><aside class="card"><h2>Typical Repaint Triggers</h2><ul class="check-list"><li>Lines are hard to see at night</li><li>Fire lanes lose red visibility</li><li>ADA markings fade or peel</li><li>Sealcoating or resurfacing is complete</li><li>Entrances and loading zones show heavy tire wear</li></ul></aside></div></section>}
  {page.type === 'thermo' && <section class="section"><div class="container split"><article><h2>Standard Traffic Paint</h2><p>Standard traffic paint is the practical choice for most parking stalls, arrows, curbs, and routine restriping. It is cost-effective and works well when pavement is dry and properly prepared.</p><h2>Thermoplastic</h2><p>Thermoplastic costs more but can last longer in high-wear areas such as stop bars, crosswalks, loading zones, warehouse traffic points, and heavy-turn entrances. It is not always worth the cost if the pavement is failing or likely to be resurfaced soon.</p></article><aside class="card"><h2>Mississippi Use Cases</h2><p>Reflective beads can improve night visibility. Warehouse lanes and loading areas may benefit from more durable markings, while standard paint is usually the better fit for routine stall lines.</p></aside></div></section>}
  {page.type === 'ada' && <section class="section"><div class="container split"><article><h2>What We Look At</h2><p>ADA parking areas commonly involve handicap spacing, access aisles, hatch marks, pavement symbols, signage placement, fire lane visibility, curb ramps, and pedestrian routes to the entrance.</p><p>Common problems include faded access aisle hatch marks, missing signs, blocked routes, too few spaces after a layout change, and fire lane markings that conflict with pedestrian access.</p></article><aside class="card"><h2>Repaint Schedule</h2><p>ADA symbols, access aisles, and fire lanes are compliance-sensitive markings. Many properties refresh these before the rest of the lot when blue, white, or red markings fade.</p><a class="button" href="/contact/#quote-form">Request ADA Evaluation</a></aside></div></section>}
  {page.type === 'layout' && <section class="section"><div class="container split"><article><h2>Layout Priorities</h2><p>We look at traffic flow, pedestrian safety, parking efficiency, ADA routes, loading zones, fire lanes, drive aisles, directional arrows, wheel stops, and apartment or retail circulation. The best layout is one drivers understand without stopping to think.</p><p>Apartment communities need tenant access. Retail lots need customer circulation. Warehouses need truck and employee separation. Medical plazas need ADA visibility and pedestrian routes.</p></article><aside class="card"><h2>Planning Details</h2><ul class="check-list"><li>Maximize usable parking without tight turns</li><li>Keep fire lanes and access aisles clear</li><li>Use arrows and stop bars where drivers hesitate</li><li>Plan around sealcoating and tenant traffic</li></ul></aside></div></section>}
  {page.type === 'local' && <section class="section"><div class="container split"><article><h2>{page.city} Pavement Marking Work</h2>{page.details.map((item) => <p>{item}</p>)}<h2>Services Available</h2><ul class="check-list"><li>Commercial lot striping and parking stall repainting</li><li>ADA stalls, access aisles, and pavement symbols</li><li>Fire lane painting, curb markings, and no-parking stencils</li><li>Directional arrows, stop bars, crosswalks, and loading zones</li><li>Overnight, weekend, or phased scheduling when practical</li></ul></article><aside class="card"><h2>Request a {page.city} Quote</h2><p>Send the property address, photos of faded markings, approximate stall count, and any schedule limits. We can usually tell whether a walkthrough is needed from that information.</p><a class="button" href="/contact/#quote-form">Upload Parking Lot Photos</a></aside></div></section>}
  <section class="section alt"><div class="container grid"><article class="card"><h2><a href="/our-striping-process/">Process</a></h2><p>Walkthrough, measurements, chalk layout, prep, paint, curing, and final inspection.</p></article><article class="card"><h2><a href="/ada-compliance-guide/">ADA Guide</a></h2><p>Access aisles, signage, fire lane visibility, and common marking issues.</p></article><article class="card"><h2><a href="/parking-lot-layout-planning/">Layout Planning</a></h2><p>Traffic flow, pedestrian safety, loading zones, apartments, and retail layouts.</p></article></div></section>
</BaseLayout>
