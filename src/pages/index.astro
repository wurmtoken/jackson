const site = 'https://jacksonlotstriping.com';
const faqs = [
 {q:'How often should a parking lot be re-striped in Jackson?',a:'Most commercial lots need fresh pavement markings every 18 to 36 months. Entrances, fire lanes, loading zones, and high-traffic shopping center aisles may need repainting sooner because of Mississippi heat, rain, and constant traffic.'},
 {q:'How long does striping paint take to dry?',a:'Drying depends on pavement temperature, humidity, shade, airflow, and paint type. Hot pavement may surface-dry quickly, but humid or rainy conditions can extend reopening windows.'},
 {q:'Can you stripe after business hours?',a:'Yes. Retail centers, warehouses, apartments, schools, churches, and medical plazas often need evening, overnight, weekend, or phased scheduling.'},
 {q:'Do you help with ADA and fire lane markings?',a:'Yes. We mark accessible stalls, access aisles, pavement symbols, red curbs, no-parking zones, and fire lane stencils. Final compliance questions should be confirmed with the property owner or local authority.'}
];
const schemas = [
 {'@context':'https://schema.org','@type':'LocalBusiness','@id':`${site}/#localbusiness`,'name':'Jackson Lot Striping','legalName':'Jackson Lot Striping','image':`${site}/images/parking-lot-line-painting.webp`,'logo':`${site}/images/parking-lot-line-painting.webp`,'url':site,'telephone':'+1-601-365-4753','address':{'@type':'PostalAddress','addressLocality':'Jackson','addressRegion':'MS','addressCountry':'US'},'geo':{'@type':'GeoCoordinates','latitude':32.2988,'longitude':-90.1848},'areaServed':[{'@type':'City','name':'Jackson'},{'@type':'City','name':'Ridgeland'},{'@type':'City','name':'Madison'},{'@type':'City','name':'Pearl'},{'@type':'City','name':'Brandon'},{'@type':'City','name':'Clinton'},{'@type':'City','name':'Flowood'},{'@type':'City','name':'Byram'}],'priceRange':'$$','openingHoursSpecification':[{'@type':'OpeningHoursSpecification','dayOfWeek':['Monday','Tuesday','Wednesday','Thursday','Friday'],'opens':'08:00','closes':'18:00'}],'makesOffer':[{'@type':'Offer','itemOffered':{'@type':'Service','name':'Parking Lot Striping'}},{'@type':'Offer','itemOffered':{'@type':'Service','name':'ADA Parking Lot Compliance Markings'}},{'@type':'Offer','itemOffered':{'@type':'Service','name':'Fire Lane Striping'}},{'@type':'Offer','itemOffered':{'@type':'Service','name':'Parking Lot Re-Striping'}}],'description':'Parking lot striping contractor serving Jackson, Mississippi and surrounding metro communities.'},
 {'@context':'https://schema.org','@type':'Service','serviceType':'Parking Lot Striping','provider':{'@id':`${site}/#localbusiness`},'areaServed':{'@type':'City','name':'Jackson'},'description':'Parking lot striping, ADA markings, fire lane painting, re-striping, and layout work in Jackson, MS.'},
 {'@context':'https://schema.org','@type':'FAQPage','mainEntity':faqs.map(f=>({'@type':'Question','name':f.q,'acceptedAnswer':{'@type':'Answer','text':f.a}}))},
 {'@context':'https://schema.org','@type':'Review','itemReviewed':{'@id':`${site}/#localbusiness`},'reviewBody':'The lot looks cleaner and customers can finally see the parking layout again. The crew worked around our traffic and reopening window.','author':{'@type':'Person','name':'Property Manager, Jackson'},'reviewRating':{'@type':'Rating','ratingValue':'5','bestRating':'5'}},
 {'@context':'https://schema.org','@type':'ImageObject','contentUrl':`${site}/images/parking-lot-line-painting.webp`,'name':'Parking lot striping equipment and fresh pavement markings'}
