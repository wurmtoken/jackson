---
import BaseLayout from '../layouts/BaseLayout.astro';
const site='https://jacksonlotstriping.com';
const schemas=[{'@context':'https://schema.org','@type':'BreadcrumbList','itemListElement':[{'@type':'ListItem','position':1,'name':'Home','item':site+'/'},{'@type':'ListItem','position':2,'name':'Contact','item':site+'/contact/'}]}];
---
<BaseLayout title="Contact Jackson Lot Striping | Request a Quote" description="Contact Jackson Lot Striping for parking lot striping quotes in Jackson, Jackson County, Blackman Township, Summit Township, Grass Lake, Michigan Center, and South Central Michigan." canonical={site + '/contact/'} schemas={schemas}>
  <section class="page-hero"><div class="container"><p class="breadcrumb"><a href="/">Home</a> / Contact</p><h1>Contact Jackson Lot Striping</h1><p>Request a quote for parking lot striping, ADA markings, fire lane striping, or re-striping in Jackson, MI.</p></div></section>
  <section class="section"><div class="container split"><article><h2>Get a fast local quote</h2><p><strong>Phone:</strong> <a href="tel:+15173654753">517-365-4753</a></p><p><strong>Email:</strong> <a href="mailto:sales@datamations.com">sales@datamations.com</a></p><p><strong>Address:</strong> Jackson, MI</p><p>Serving Jackson, Jackson County, Blackman Township, Summit Township, Grass Lake, Michigan Center, and South Central Michigan.</p></article><article class="quote-card"><h2>Request Quote</h2><form id="quote-form" class="form-grid" name="quote" method="post" action="https://formsubmit.co/sales@datamations.com"><input type="hidden" name="_subject" value="Jackson Lot Striping contact form" /><input type="hidden" name="_template" value="table" /><input type="hidden" name="_captcha" value="false" /><input name="name" placeholder="Name" required /><input name="phone" placeholder="Phone" required /><input name="email" type="email" placeholder="Email" /><select name="service"><option>Parking lot striping</option><option>ADA compliance</option><option>Fire lane striping</option><option>Parking lot re-striping</option></select><textarea name="message" rows="6" placeholder="Property address and project details"></textarea><button class="button" type="submit">Send Request</button></form></article></div></section>
</BaseLayout>
