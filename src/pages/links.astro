---
import BaseLayout from '../layouts/BaseLayout.astro';
const site='https://jacksonlotstriping.com';
const resources=[
  {title:'City of Jackson',url:'https://www.jacksonms.gov/',description:'Local city information useful for commercial property owners and managers.'},
  {title:'Hinds County',url:'https://www.hindscountyms.com/',description:'County resources for Jackson-area properties and local planning.'},
  {title:'Mississippi Department of Transportation',url:'https://mdot.ms.gov/',description:'State transportation information and roadway resources for Mississippi.'},
  {title:'ADA.gov',url:'https://www.ada.gov/',description:'Federal accessibility guidance for public accommodations and commercial properties.'},
  {title:'Our Striping Process',url:'/our-striping-process/',description:'How a striping job moves from walkthrough and measurements to chalk layout, paint, curing, and final inspection.'},
  {title:'Restriping After Sealcoating',url:'/restriping-after-sealcoating/',description:'Planning notes for repainting a parking lot after sealcoating in Mississippi heat and humidity.'}
];
const schemas=[{'@context':'https://schema.org','@type':'BreadcrumbList','itemListElement':[{'@type':'ListItem','position':1,'name':'Home','item':site+'/'},{'@type':'ListItem','position':2,'name':'Jackson Parking Lot Resources','item':site+'/links/'}]}];
---
<BaseLayout title="Jackson Parking Lot Resources | Jackson Lot Striping" description="Local pavement marking, ADA, weather, sealcoating, fire lane, and asphalt maintenance resources for Jackson MS property managers." canonical={site + '/links/'} schemas={schemas}>
  <section class="page-hero"><div class="container"><p class="breadcrumb"><a href="/">Home</a> / Resources</p><h1>Jackson Parking Lot Resources</h1><p>Practical resources for property managers planning striping, ADA markings, fire lanes, sealcoating, and layout work around Jackson, Mississippi.</p></div></section>
  <section class="section"><div class="container grid">{resources.map((link)=><article class="card"><h2>{link.title}</h2><p>{link.description}</p><a class="button" href={link.url} target={link.url.startsWith('http') ? '_blank' : undefined} rel={link.url.startsWith('http') ? 'noopener noreferrer' : undefined}>Visit Resource</a></article>)}</div></section>
</BaseLayout>
